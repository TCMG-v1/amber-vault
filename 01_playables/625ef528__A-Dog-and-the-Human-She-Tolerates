}
.stack-lede {
  font-family: var(--font-display); font-style: italic;
  font-size: 0.98rem; color: var(--text-dim);
  line-height: 1.6; margin-bottom: 1.4rem; max-width: 60ch;
}
.estack { display: flex; flex-direction: column; gap: 0.7rem; }
.erow {
  display: grid;
  grid-template-columns: 56px 1fr;
  gap: 1.1rem;
  padding: 1.1rem 1.25rem;
  background: rgba(255, 232, 200, 0.018);
  border: 1px solid var(--hairline);
  border-left: 2px solid var(--accent, var(--gold-lit));
  transition: border-color .25s ease, background .25s ease;
}
.erow:hover { border-left-color: var(--vermilion-lit); background: rgba(168, 50, 45, 0.04); }
.erow .glyph {
  font-family: var(--font-han);
  font-size: 2.1rem; line-height: 1;
  color: var(--gold-lit);
  text-shadow: 0 0 14px rgba(212, 175, 55, 0.45);
  align-self: start;
  padding-top: 0.15rem;
}
.erow .body { display: flex; flex-direction: column; gap: 0.5rem; }
.erow .top {
  display: flex; flex-wrap: wrap; align-items: baseline;
