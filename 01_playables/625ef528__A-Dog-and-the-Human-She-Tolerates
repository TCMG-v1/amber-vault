/* ─── .PIXEL CARDS ─────────────────────────────────────────── */
.pixels {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.25rem;
}
.pixel {
  position: relative;
  padding: 1.5rem;
  background:
    linear-gradient(180deg, rgba(255, 232, 200, 0.045), rgba(255, 232, 200, 0.01)),
    var(--leather-mid);
  border: 1px solid var(--hairline-strong);
  font-family: var(--font-mono);
  transition: border-color .3s ease, transform .3s ease, box-shadow .3s ease;
}
.pixel:hover {
  border-color: var(--gold-lit);
  transform: translateY(-2px);
  box-shadow: 0 0 24px rgba(212, 175, 55, 0.18);
}
.pixel .px-head {
  display: flex; justify-content: space-between; align-items: center;
  font-size: 0.62rem; letter-spacing: 0.26em; text-transform: uppercase;
  color: var(--gold-lit);
  text-shadow: 0 0 8px rgba(212, 175, 55, 0.4);
  margin-bottom: 1.1rem;
  padding-bottom: 0.85rem;
  border-bottom: 1px dotted var(--hairline-strong);
