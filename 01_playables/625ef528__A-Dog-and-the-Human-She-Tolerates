}
.stream .row {
  display: flex; justify-content: space-between;
  font-family: var(--font-mono); font-size: 0.72rem;
  padding: 0.55rem 0; border-top: 1px dotted var(--hairline);
  color: var(--text-dim); margin-top: 0.6rem;
}
.stream .row:first-of-type { margin-top: 1.2rem; }
.stream .row b { color: var(--text); font-weight: 500; }
.stream.s1 { --accent: var(--vermilion-lit); }
