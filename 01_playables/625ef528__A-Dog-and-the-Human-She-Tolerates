.pixel.draft .px-head .num::after {
  content: " · draft"; color: var(--text-faint);
  font-style: italic;
  text-shadow: none;
}

/* ─── ACTIONS ──────────────────────────────────────────────── */
.actions {
  display: grid;
  grid-template-columns: 1fr;
  gap: 0.85rem;
}
.action {
  display: grid;
  grid-template-columns: 80px 1fr auto;
  gap: 1.5rem;
  align-items: center;
  padding: 1.25rem 1.5rem;
  background: linear-gradient(90deg, rgba(212, 175, 55, 0.04), transparent 30%);
  border: 1px solid var(--hairline-strong);
  border-left: 2px solid var(--gold);
  transition: all .25s ease;
}
.action:hover {
  background: linear-gradient(90deg, rgba(212, 175, 55, 0.08), transparent 40%);
  border-left-color: var(--gold-lit);
}
.action .step {
  font-family: var(--font-mono); font-size: 0.85rem;
  color: var(--gold-lit);
  letter-spacing: 0.2em;
  text-shadow: 0 0 10px rgba(212, 175, 55, 0.4);
}
.action .body {
  font-family: var(--font-display);
  font-size: 1.05rem; color: var(--text);
  line-height: 1.55;
  font-style: italic;
}
.action .body b { color: var(--paper); font-style: normal; font-weight: 600; }
.action .when {
  font-family: var(--font-mono); font-size: 0.68rem;
  letter-spacing: 0.22em; text-transform: uppercase;
  color: var(--text-faint);
  white-space: nowrap;
}
@media (max-width: 720px) {
  .action { grid-template-columns: 1fr; gap: 0.5rem; }
  .action .when { justify-self: start; }
}

