<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>道場 ATLAS · bounded-time · edition 01</title>
<meta name="description" content="A cybernetic leatherbound journal. One operating system across six domains. Bounded-time as causal substrate. CHRONOS as executable layer. HELIX as mathematical proof." />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=JetBrains+Mono:wght@300;400;500;700&family=Inter:wght@400;500;600&family=Noto+Serif+SC:wght@400;700&family=Noto+Sans+Devanagari:wght@400;700&family=Noto+Sans+Arabic:wght@400;700&display=swap" rel="stylesheet" />
<style>
:root {
  /* Leather substrate — warmer than pure noir */
  --leather-deep: #0d0807;     /* deepest crease */
  --leather: #15100d;          /* base hide */
  --leather-mid: #1f1612;      /* lit hide */
  --leather-lit: #2a1d17;      /* edge of light */
  --oxblood: #3a1817;          /* deep red-leather undertone */

  /* Vermilion Gate, sealed and lit */
  --vermilion: #c8332e;        /* base vermilion (Gate) */
  --vermilion-lit: #ff2a4a;    /* neon-graft vermilion */
  --gold: #d4af37;             /* weathered gold (Record) */
  --gold-lit: #ffd86b;         /* lit gold leaf */
  --ember: #e87830;            /* Ember (transition glow) */
  --paper: #f4ecdd;            /* aged paper / cream */
  --ink: #1c1c1b;              /* Soot */

  /* Cybernetic accents (restrained — used as edge-glow, not body) */
  --cyber-cyan: #5fd7ff;
  --cyber-mint: #5cffb1;
  --cyber-violet: #c98bff;
  --cyber-magenta: #ff7ad6;

  /* Text grades on leather */
  --text: #ede2cb;
  --text-dim: #b8a786;
  --text-faint: #7a6a52;
  --hairline: rgba(212, 175, 55, 0.14);
  --hairline-strong: rgba(212, 175, 55, 0.30);
  --rule: rgba(212, 175, 55, 0.45);

  --font-display: 'Cormorant Garamond', 'EB Garamond', Georgia, serif;
  --font-body: 'Cormorant Garamond', Georgia, serif;
  --font-ui: 'Inter', system-ui, sans-serif;
  --font-mono: 'JetBrains Mono', ui-monospace, monospace;
  --font-han: 'Noto Serif SC', serif;
  --font-deva: 'Noto Sans Devanagari', sans-serif;
  --font-arab: 'Noto Sans Arabic', sans-serif;
}

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }

body {
  background: var(--leather);
  color: var(--text);
  font-family: var(--font-body);
  font-weight: 400;
  font-size: 18px;
  line-height: 1.62;
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  position: relative;
}

/* ─── LEATHER BACKDROP ─────────────────────────────────────── */
/* Layered: gradient depth + procedural grain via radial dots + oxblood breath */
body::before {
  content: "";
  position: fixed; inset: 0; pointer-events: none; z-index: 0;
  background:
    radial-gradient(ellipse 1400px 800px at 50% -10%, var(--oxblood) 0%, transparent 55%),
    radial-gradient(ellipse 1100px 700px at 10% 105%, rgba(58, 24, 23, 0.6) 0%, transparent 60%),
    radial-gradient(ellipse 1100px 700px at 90% 105%, rgba(58, 24, 23, 0.4) 0%, transparent 60%),
    linear-gradient(180deg, var(--leather-deep) 0%, var(--leather) 50%, var(--leather-deep) 100%);
}
body::after {
  content: "";
  position: fixed; inset: 0; pointer-events: none; z-index: 0;
  /* Procedural leather grain — multi-layer radial noise */
  background-image:
    radial-gradient(rgba(0,0,0,0.30) 1px, transparent 1.2px),
    radial-gradient(rgba(212,175,55,0.025) 0.5px, transparent 1px);
  background-size: 3px 3px, 7px 7px;
  background-position: 0 0, 1px 2px;
  opacity: 0.55;
  mix-blend-mode: overlay;
}

main, header, footer, section { position: relative; z-index: 1; }

/* ─── TYPOGRAPHY ───────────────────────────────────────────── */
h1, h2, h3, h4 {
  font-family: var(--font-display);
  letter-spacing: -0.01em;
  line-height: 1.08;
  font-weight: 500;
}
h1 { font-size: clamp(2.75rem, 7vw, 6.5rem); font-weight: 500; letter-spacing: -0.02em; }
h2 { font-size: clamp(2rem, 4vw, 3.25rem); font-weight: 500; }
h3 { font-size: clamp(1.35rem, 2vw, 1.75rem); font-weight: 600; font-style: italic; }
h4 { font-size: 1.1rem; font-weight: 600; }

p { color: var(--text); }
.mono { font-family: var(--font-mono); font-variant-ligatures: none; }
.ui { font-family: var(--font-ui); }
.dim { color: var(--text-dim); }
.faint { color: var(--text-faint); }
em { font-style: italic; color: var(--gold-lit); text-shadow: 0 0 14px rgba(212, 175, 55, 0.35); }
b, strong { color: var(--paper); font-weight: 600; }

a { color: var(--gold-lit); text-decoration: none; transition: color .2s ease; border-bottom: 1px dotted rgba(212,175,55,0.4); }
a:hover { color: var(--paper); border-bottom-color: var(--paper); }

/* Small caps utility for UI labels — used like tooling-stamp lettering */
.tooled {
  font-family: var(--font-ui);
  font-weight: 500;
  font-size: 0.66rem;
  letter-spacing: 0.36em;
  text-transform: uppercase;
  color: var(--gold);
  text-shadow: 0 0 12px rgba(212, 175, 55, 0.25);
}

/* ─── GOLD TOOLED RULES (the binding) ──────────────────────── */
.tooled-rule {
  height: 1px;
  background: linear-gradient(90deg,
    transparent 0%,
    rgba(212,175,55,0.0) 4%,
    var(--gold) 12%,
    var(--gold-lit) 50%,
    var(--gold) 88%,
    rgba(212,175,55,0.0) 96%,
    transparent 100%);
  box-shadow: 0 0 12px rgba(212, 175, 55, 0.3);
  margin: 0;
}
.tooled-double {
  display: block;
  position: relative;
  padding: 4px 0;
}
.tooled-double::before, .tooled-double::after {
  content: ""; display: block; height: 1px;
  background: linear-gradient(90deg, transparent, var(--gold), transparent);
  box-shadow: 0 0 8px rgba(212, 175, 55, 0.4);
}
.tooled-double::after { margin-top: 3px; }

/* ─── COVER FRAME (the bound spread) ───────────────────────── */
.cover {
  max-width: 1320px;
  margin: 0 auto;
  padding: 2rem 1.5rem;
  position: relative;
}

/* Ribbon bookmark — SVG positioned absolutely from the cover top */
.ribbon {
  position: absolute;
  top: 0;
  right: 20px;
  width: 28px;
  height: 140px;
  pointer-events: none;
  z-index: 1;
  opacity: 0.85;
  filter: drop-shadow(0 6px 14px rgba(0,0,0,0.6));
}
@media (max-width: 900px) { .ribbon { display: none; } }

/* ─── HEADER / MASTHEAD ─────────────────────────────────────── */
header.masthead {
  padding: 3rem 0 2rem;
  border-bottom: none;
  position: relative;
}
.masthead-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 2rem;
  margin-bottom: 1.5rem;
  padding-right: 60px; /* clear the ribbon bookmark */
}
.masthead-left { display: flex; align-items: center; gap: 1.25rem; }
.masthead-han {
  font-family: var(--font-han);
  font-size: 2rem;
  color: var(--vermilion-lit);
  text-shadow: 0 0 18px rgba(255, 42, 74, 0.55), 0 0 2px var(--vermilion-lit);
  line-height: 1;
}
.masthead-titleblock { display: flex; flex-direction: column; gap: 0.35rem; }
.masthead-title { font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: 1.1rem; color: var(--paper); letter-spacing: 0.02em; }
.masthead-title b { font-style: normal; color: var(--gold-lit); font-weight: 600; letter-spacing: 0.06em; }
.masthead-sub { font-family: var(--font-mono); font-size: 0.7rem; color: var(--text-faint); letter-spacing: 0.22em; text-transform: uppercase; }

.masthead-nav { display: flex; gap: 1.5rem; flex-wrap: wrap; }
.masthead-nav a {
  font-family: var(--font-ui); font-weight: 500;
  font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase;
  color: var(--text-dim); border: none;
  position: relative; padding-bottom: 4px;
}
.masthead-nav a:hover { color: var(--gold-lit); }
.masthead-nav a::after {
  content: ""; position: absolute; left: 0; bottom: 0; height: 1px; width: 0;
  background: var(--gold-lit);
  box-shadow: 0 0 8px var(--gold-lit);
  transition: width .3s ease;
}
.masthead-nav a:hover::after { width: 100%; }
@media (max-width: 780px) { .masthead-nav { display: none; } }

/* ─── HERO ─────────────────────────────────────────────────── */
.hero {
  padding: 4rem 0 5rem;
  position: relative;
}
.hero-kicker {
  display: inline-flex; align-items: center; gap: 1rem;
  margin-bottom: 2rem;
}
.hero-kicker::before {
  content: ""; width: 48px; height: 1px;
  background: var(--vermilion-lit);
  box-shadow: 0 0 10px var(--vermilion-lit);
}
.hero-kicker .lbl {
  font-family: var(--font-mono); font-size: 0.7rem;
  letter-spacing: 0.32em; text-transform: uppercase;
  color: var(--vermilion-lit);
  text-shadow: 0 0 12px rgba(255, 42, 74, 0.45);
}

.hero h1 {
  color: var(--paper);
  margin-bottom: 1.5rem;
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
  text-shadow: 0 1px 0 rgba(0,0,0,0.4);
}
.hero h1 .han {
  font-family: var(--font-han);
  font-style: normal;
  color: var(--vermilion-lit);
  text-shadow: 0 0 28px rgba(255, 42, 74, 0.6), 0 0 4px var(--vermilion);
  margin-right: 0.15em;
  letter-spacing: 0.02em;
}
.hero h1 .gilded {
  font-style: normal;
  background: linear-gradient(135deg, var(--gold) 0%, var(--gold-lit) 45%, var(--paper) 65%, var(--gold-lit) 100%);
  -webkit-background-clip: text; background-clip: text;
  -webkit-text-fill-color: transparent;
  text-shadow: 0 0 32px rgba(212, 175, 55, 0.25);
  letter-spacing: 0.01em;
}

/* Drop cap — illuminated-manuscript treatment */
.hero-sub {
  font-size: clamp(1.05rem, 1.4vw, 1.35rem);
  color: var(--text);
  max-width: 720px;
  line-height: 1.7;
  font-family: var(--font-display);
}
.hero-sub::first-letter {
  font-family: var(--font-display);
  font-size: 3.25em;
  font-weight: 500;
  float: left;
  line-height: 0.85;
  padding: 0.05em 0.12em 0 0;
  color: var(--vermilion-lit);
  text-shadow: 0 0 18px rgba(255, 42, 74, 0.45);
}

/* Meta strip — like the colophon block */
.colophon {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 1.5rem 2rem;
  padding: 2rem 0 0;
  margin-top: 2.5rem;
  border-top: 1px solid var(--hairline);
  position: relative;
}
.colophon::before, .colophon::after {
  content: "❦"; /* floral heart — illuminated-mss ornament */
  position: absolute;
  top: -0.7em;
  background: var(--leather);
  color: var(--gold);
  text-shadow: 0 0 12px rgba(212, 175, 55, 0.5);
  padding: 0 0.6rem;
  font-size: 0.85rem;
}
.colophon::before { left: 50%; transform: translateX(-50%); }
.colophon::after { display: none; }

.colo-cell .lbl { display: block; margin-bottom: 0.55rem; }
.colo-cell .val {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.02rem;
  color: var(--text);
  line-height: 1.45;
}
.colo-cell .val b { color: var(--paper); font-style: normal; font-weight: 600; }
.colo-cell .val .acc {
  color: var(--gold-lit);
  text-shadow: 0 0 10px rgba(212, 175, 55, 0.4);
  font-style: normal;
}
.colo-cell .val .han-inline {
  font-family: var(--font-han); font-style: normal;
  color: var(--vermilion-lit);
  text-shadow: 0 0 12px rgba(255, 42, 74, 0.45);
}

/* ─── SECTION BLOCK ────────────────────────────────────────── */
section.book {
  padding: 4rem 0;
  position: relative;
}
.book + .book { border-top: none; }

.book-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  flex-wrap: wrap;
  gap: 1.5rem;
  margin-bottom: 2rem;
  padding-top: 2rem;
}
.book-head-left { display: flex; align-items: center; gap: 1.5rem; }

/* Wax seal sigil — circular, embossed */
.sigil {
  width: 76px; height: 76px;
  flex-shrink: 0;
  position: relative;
  display: grid; place-items: center;
  border-radius: 50%;
  background: radial-gradient(circle at 30% 30%, var(--vermilion-lit) 0%, var(--vermilion) 35%, #6b1a18 75%, #2a0807 100%);
  box-shadow:
    inset 0 2px 4px rgba(255,255,255,0.18),
    inset 0 -4px 8px rgba(0,0,0,0.5),
    0 0 24px rgba(255, 42, 74, 0.35),
    0 4px 14px rgba(0,0,0,0.6);
  filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
}
.sigil::before {
  content: ""; position: absolute; inset: 6px;
  border-radius: 50%;
  border: 1px dashed rgba(255, 230, 200, 0.25);
}
.sigil .han {
  font-family: var(--font-han);
  font-size: 2.2rem;
  color: rgba(255, 232, 210, 0.95);
  text-shadow: 0 1px 0 rgba(0,0,0,0.4), 0 0 8px rgba(255, 220, 200, 0.4);
  line-height: 1;
}

.book-title { display: flex; flex-direction: column; gap: 0.4rem; }
.book-title h2 { color: var(--paper); font-style: italic; font-weight: 500; }
.book-title .tooled { color: var(--gold); }

.book-num {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.3em;
  text-transform: uppercase;
  color: var(--gold);
  text-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
  padding: 0.4rem 0.9rem;
  border: 1px solid var(--hairline-strong);
  background: rgba(20, 14, 11, 0.6);
}

.book-lede {
  font-size: clamp(1.05rem, 1.3vw, 1.2rem);
  color: var(--text);
  max-width: 820px;
  line-height: 1.7;
  margin-bottom: 2.5rem;
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 400;
}
.book-lede b { font-style: normal; }

/* ─── SUBSTRATE DIAGRAM ────────────────────────────────────── */
.substrate {
  display: grid;
  grid-template-columns: repeat(12, 1fr);
  gap: 1rem;
}
.substrate-row {
  grid-column: 1 / -1;
  display: grid; grid-template-columns: repeat(12, 1fr); gap: 1rem; align-items: stretch;
}
.leaf {
  padding: 1.5rem 1.75rem;
  background: linear-gradient(180deg, rgba(255, 232, 200, 0.04) 0%, rgba(255, 232, 200, 0.015) 100%);
  border: 1px solid var(--hairline-strong);
  position: relative;
  display: flex; flex-direction: column; gap: 0.65rem;
}
.leaf::before {
  /* gold edge accent on top */
  content: ""; position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent, var(--gold-lit)), transparent);
  box-shadow: 0 0 10px var(--accent, var(--gold-lit));
}
.leaf::after {
  /* corner notch — codex-page hint */
  content: ""; position: absolute; top: 0; right: 0;
  width: 14px; height: 14px;
  background: linear-gradient(135deg, transparent 50%, var(--leather-deep) 50%);
}
.leaf .leaf-role {
  font-family: var(--font-mono); font-size: 0.65rem;
  letter-spacing: 0.28em; text-transform: uppercase;
  color: var(--accent, var(--gold));
  text-shadow: 0 0 10px var(--accent, var(--gold));
}
.leaf h3 {
  color: var(--paper);
  font-family: var(--font-display);
  font-style: italic;
  font-weight: 600;
}
.leaf p {
  color: var(--text-dim);
  font-family: var(--font-display);
  font-size: 1rem;
  line-height: 1.55;
}
.leaf p b { color: var(--text); font-weight: 600; }

.leaf.spine { grid-column: 3 / 11; --accent: var(--vermilion-lit); }
.leaf.exec  { grid-column: 3 / 11; --accent: var(--cyber-violet); }
.leaf.dom   { grid-column: span 4; --accent: var(--gold-lit); }
@media (max-width: 980px) {
  .leaf.spine, .leaf.exec { grid-column: 1 / -1; }
  .leaf.dom { grid-column: 1 / -1; }
}

.connector {
  grid-column: 1 / -1;
  height: 44px;
  display: grid; place-items: center;
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.32em;
  color: var(--gold);
  text-transform: uppercase;
  position: relative;
}
.connector::before, .connector::after {
  content: ""; position: absolute; top: 50%;
  height: 1px; width: 80px;
  background: linear-gradient(90deg, transparent, var(--gold));
}
.connector::before { left: calc(50% - 160px); }
.connector::after { right: calc(50% - 160px); background: linear-gradient(90deg, var(--gold), transparent); }
.connector span { padding: 0 1rem; background: var(--leather); }

/* ─── DOMAINS GRID ─────────────────────────────────────────── */
.domains {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
  gap: 1.5rem;
}
.domain {
  position: relative;
  padding: 1.75rem 1.75rem 1.5rem;
  background: linear-gradient(180deg, rgba(255, 232, 200, 0.04) 0%, rgba(255, 232, 200, 0.01) 100%);
  border: 1px solid var(--hairline-strong);
  transition: transform .3s ease, border-color .3s ease, box-shadow .3s ease;
  overflow: hidden;
}
.domain::before {
  /* tooled gold double-rule top, with accent inside */
  content: ""; position: absolute; top: 6px; left: 1.75rem; right: 1.75rem;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
  box-shadow: 0 0 12px var(--accent), 0 4px 0 -3px var(--gold);
}
.domain::after {
  /* thread-stitch hint on the spine side */
  content: ""; position: absolute; left: 0; top: 18px; bottom: 18px;
  width: 2px;
  background: repeating-linear-gradient(
    to bottom,
    var(--accent) 0px, var(--accent) 4px,
    transparent 4px, transparent 10px
  );
  box-shadow: 0 0 8px var(--accent);
  opacity: 0.5;
}
.domain:hover {
  transform: translateY(-3px);
  border-color: var(--accent);
  box-shadow: 0 14px 40px rgba(0,0,0,0.55), 0 0 24px rgba(212, 175, 55, 0.12);
}
.domain:hover::after { opacity: 1; }

.dom-tag {
  display: flex; justify-content: space-between; align-items: center;
  margin-top: 0.5rem;
  margin-bottom: 1rem;
}
.dom-tag .role {
  font-family: var(--font-mono); font-size: 0.65rem;
  letter-spacing: 0.28em; text-transform: uppercase;
  color: var(--accent);
  text-shadow: 0 0 10px var(--accent);
}
.dom-tag .state {
  font-family: var(--font-mono); font-size: 0.65rem;
  letter-spacing: 0.18em;
  color: var(--accent);
  padding: 0.2rem 0.7rem;
  border: 1px solid var(--accent);
  border-radius: 999px;
}
.domain h3 {
  color: var(--paper);
  font-style: italic;
  margin-bottom: 0.4rem;
  font-weight: 600;
  display: flex; align-items: baseline; gap: 0.6rem;
}
.domain h3 .han-head {
  font-family: var(--font-han);
  font-style: normal;
  font-weight: 400;
  color: var(--accent);
  text-shadow: 0 0 16px var(--accent);
  font-size: 1.4em;
  line-height: 1;
}
.domain .thesis {
  color: var(--text-dim);
  font-family: var(--font-display);
  font-size: 1rem;
  font-style: italic;
  line-height: 1.6;
  margin-bottom: 1.1rem;
}
.domain ul {
  list-style: none;
  border-top: 1px dotted var(--hairline-strong);
  padding-top: 0.85rem;
}
.domain ul li {
  font-family: var(--font-mono); font-size: 0.78rem;
  color: var(--text-dim);
  padding: 0.25rem 0;
  display: grid; grid-template-columns: 90px 1fr; gap: 0.8rem;
  line-height: 1.45;
}
.domain ul li .k {
  color: var(--text-faint);
  letter-spacing: 0.14em;
  text-transform: uppercase;
  font-size: 0.62rem;
  padding-top: 0.2rem;
}
.domain ul li .v { color: var(--text); }
.domain ul li .v.map { color: var(--gold-lit); text-shadow: 0 0 8px rgba(212, 175, 55, 0.3); }

.domain.d1 { --accent: var(--vermilion-lit); }
.domain.d2 { --accent: var(--cyber-cyan); }
.domain.d3 { --accent: var(--cyber-mint); }
.domain.d4 { --accent: var(--cyber-violet); }
.domain.d5 { --accent: var(--ember); }
.domain.d6 { --accent: var(--gold-lit); }

/* ─── THREE PILLARS ────────────────────────────────────────── */
.triad {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
}
@media (max-width: 880px) { .triad { grid-template-columns: 1fr; } }

.pillar {
  padding: 2.5rem 1.75rem;
  background: radial-gradient(ellipse at top, rgba(212, 175, 55, 0.06) 0%, transparent 70%);
  border: 1px solid var(--hairline-strong);
  text-align: center;
  position: relative;
}
.pillar::before {
  content: ""; position: absolute; top: 0; left: 50%; transform: translateX(-50%);
  width: 60%; height: 2px;
  background: linear-gradient(90deg, transparent, var(--accent), transparent);
