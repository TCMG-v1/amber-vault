.sequence-head {
  font-family: var(--font-mono);
  font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase;
  color: var(--gold);
  text-shadow: 0 0 10px rgba(212, 175, 55, 0.35);
  margin-bottom: 1.25rem;
  padding-top: 1rem;
  border-top: 1px dotted var(--hairline-strong);
}
.sequence {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr));
  gap: 0.85rem;
}
.term {
  padding: 1.1rem 1.1rem 1rem;
  font-family: var(--font-mono); font-size: 0.78rem;
  background: rgba(255, 232, 200, 0.02);
  border: 1px solid var(--hairline);
  transition: border-color .2s ease;
}
.term:hover { border-color: var(--gold-lit); }
.term .t-num {
  color: var(--gold-lit); letter-spacing: 0.24em;
  font-size: 0.62rem; text-transform: uppercase;
  margin-bottom: 0.6rem;
  text-shadow: 0 0 8px rgba(212, 175, 55, 0.3);
}
.term .t-courses { color: var(--text); line-height: 1.55; font-size: 0.78rem; }
.term .t-courses b { color: var(--paper); font-weight: 500; }

/* ─── EDUCATION STACK (per-domain runbook) ─────────────────── */
.stack-head {
  font-family: var(--font-mono);
  font-size: 0.7rem; letter-spacing: 0.28em; text-transform: uppercase;
  color: var(--vermilion-lit);
