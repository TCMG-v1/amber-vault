.pixel .px-head .num { color: var(--vermilion-lit); text-shadow: 0 0 8px rgba(255, 42, 74, 0.4); }
.pixel .px-row {
  display: grid; grid-template-columns: 38px 1fr; gap: 1rem; align-items: baseline;
  padding: 0.3rem 0;
  font-size: 0.82rem;
}
.pixel .px-row .gly {
  font-size: 1.4rem; line-height: 1;
  text-align: center;
  color: var(--paper);
  text-shadow: 0 1px 0 rgba(0,0,0,0.5);
}
.pixel .px-row.han .gly {
  font-family: var(--font-han);
  color: var(--vermilion-lit);
  text-shadow: 0 0 14px rgba(255, 42, 74, 0.5);
}
.pixel .px-row.dev .gly {
  font-family: var(--font-deva);
  color: var(--gold-lit);
  text-shadow: 0 0 12px rgba(212, 175, 55, 0.5);
  font-size: 1.2rem;
}
.pixel .px-row.ara .gly {
  font-family: var(--font-arab);
  color: var(--cyber-cyan);
  text-shadow: 0 0 12px rgba(95, 215, 255, 0.5);
}
.pixel .px-row.lig .gly {
  color: var(--cyber-mint);
  text-shadow: 0 0 12px rgba(92, 255, 177, 0.5);
}
.pixel .px-row.sym .gly {
  color: var(--cyber-violet);
  text-shadow: 0 0 12px rgba(201, 139, 255, 0.5);
}
.pixel .px-row .desc {
  color: var(--text-dim);
  font-family: var(--font-display);
  font-style: italic;
  font-size: 0.92rem;
  line-height: 1.5;
}
