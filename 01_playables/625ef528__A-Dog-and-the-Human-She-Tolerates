/* ─── EDUCATION STREAMS ────────────────────────────────────── */
.streams {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 1.5rem;
  margin-bottom: 2.5rem;
}
.stream {
  position: relative;
  padding: 1.75rem;
